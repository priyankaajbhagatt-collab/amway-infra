terraform {
  required_version = ">= 1.5"
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

# Per-service AWS region — set at scaffold time from the form.
# Different services can target different regions based on data locality,
# latency requirements, or compliance constraints.
provider "aws" {
  region = "us-east-1"
}

# CodePipeline for test-codepipeline-v1 → usa
# Region: us-east-1
#
# This file was generated by the Backstage scaffolder template. It instantiates
# the shared `codepipeline` Terraform module. Update inputs here, not in the module.
#
# To apply: this is normally picked up by the IaC repo's Terraform CI on merge.

module "test_codepipeline_v1_usa" {
  source = "../../../modules/codepipeline"

  pipeline_name      = "test-codepipeline-v1-usa"
  service_name       = "test-codepipeline-v1"
  market             = "usa"
  region             = "us-east-1"
  group              = "commerce/orderas"

  source_repo        = "priyankaajbhagatt-collab/test-codepipeline-v1"
  source_branch      = "main"

  build_image        = "python"
  buildspec_path     = "buildspec.yml"

  # CD stage notifies ArgoCD via webhook — app naming convention matches
  # what CompositeLiveProvider.linkArgoApps() expects.
  argocd_app_name    = "test-codepipeline-v1-usa"

  tags = {
    Service     = "test-codepipeline-v1"
    Market      = "usa"
    Region      = "us-east-1"
    Group       = "commerce/orderas"
    ManagedBy   = "backstage-scaffolder"
  }
}

output "pipeline_arn" {
  value = module.test_codepipeline_v1_usa.pipeline_arn
}
